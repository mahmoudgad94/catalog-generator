{% extends 'admin/layout.html.twig' %}

{% block title %}Tags{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Tags</h1>
    <a href="{{ path('admin_tag_new') }}" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> New Tag
    </a>
</div>

<div class="card">
    <table class="table table-hover mb-0">
        <thead>
            <tr>
                <th>Name</th>
                <th>Products</th>
                <th width="120">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for tag in tags %}
            <tr>
                <td>{{ tag.name }}</td>
                <td>{{ tag.products|length }}</td>
                <td>
                    <a href="{{ path('admin_tag_edit', {id: tag.id}) }}" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                    <form method="post" action="{{ path('admin_tag_delete', {id: tag.id}) }}" class="d-inline" onsubmit="return confirm('Delete this tag?')">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ tag.id) }}">
                        <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                    </form>
                </td>
            </tr>
            {% else %}
            <tr><td colspan="3" class="text-muted">No tags yet.</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
