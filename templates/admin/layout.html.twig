<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Catalog Generator{% endblock %} - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <style>
        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            bottom: 0;
            width: 220px;
            background-color: #212529;
            display: flex;
            flex-direction: column;
            overflow-y: auto;
            z-index: 100;
        }
        .sidebar .nav-link {
            color: #adb5bd;
            padding: 0.75rem 1rem;
        }
        .sidebar .nav-link:hover,
        .sidebar .nav-link.active {
            color: #fff;
            background-color: #343a40;
        }
        .sidebar .nav-link i {
            margin-right: 0.5rem;
        }
        .sidebar-logout {
            margin-top: auto;
            padding: 0.75rem;
        }
        .content-wrapper {
            margin-left: 220px;
            min-height: 100vh;
        }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>
    <!-- Sidebar -->
    <nav class="sidebar d-none d-md-flex">
        <div class="p-3">
            <h5 class="text-white mb-0">Catalog Generator</h5>
        </div>
        <hr class="text-secondary mt-0">
        <ul class="nav flex-column">
            <li class="nav-item">
                <a class="nav-link {% if app.request.attributes.get('_route') starts with 'admin_dashboard' %}active{% endif %}" href="{{ path('admin_dashboard') }}">
                    <i class="bi bi-speedometer2"></i> Dashboard
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link {% if app.request.attributes.get('_route') starts with 'admin_product' %}active{% endif %}" href="{{ path('admin_product_index') }}">
                    <i class="bi bi-box-seam"></i> Products
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link {% if app.request.attributes.get('_route') starts with 'admin_category' %}active{% endif %}" href="{{ path('admin_category_index') }}">
                    <i class="bi bi-diagram-3"></i> Categories
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link {% if app.request.attributes.get('_route') starts with 'admin_tag' %}active{% endif %}" href="{{ path('admin_tag_index') }}">
                    <i class="bi bi-tags"></i> Tags
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link {% if app.request.attributes.get('_route') starts with 'admin_custom_field' %}active{% endif %}" href="{{ path('admin_custom_field_index') }}">
                    <i class="bi bi-sliders"></i> Custom Fields
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link {% if app.request.attributes.get('_route') starts with 'admin_import' %}active{% endif %}" href="{{ path('admin_import') }}">
                    <i class="bi bi-upload"></i> Import CSV
                </a>
            </li>
            <hr class="text-secondary">
            <li class="nav-item">
                <a class="nav-link {% if app.request.attributes.get('_route') starts with 'admin_catalog' %}active{% endif %}" href="{{ path('admin_catalog_index') }}">
                    <i class="bi bi-journal-richtext"></i> Catalogs
                </a>
            </li>
        </ul>
        <div class="sidebar-logout">
            <hr class="text-secondary">
            <a href="{{ path('admin_logout') }}" class="nav-link text-secondary">
                <i class="bi bi-box-arrow-left"></i> Logout
            </a>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="content-wrapper p-4">
                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endfor %}
                {% endfor %}

                {% block body %}{% endblock %}
    </main>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    {% block javascripts %}{% endblock %}
</body>
</html>
