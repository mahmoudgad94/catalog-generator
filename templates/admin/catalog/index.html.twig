{% extends 'admin/layout.html.twig' %}

{% block title %}Catalogs{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Catalogs</h1>
    <a href="{{ path('admin_catalog_new') }}" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> New Catalog
    </a>
</div>

<div class="card">
    <table class="table table-hover mb-0">
        <thead>
            <tr>
                <th>Name</th>
                <th>Template</th>
                <th>Access</th>
                <th>Published</th>
                <th>Public URL</th>
                <th width="200">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for catalog in catalogs %}
            <tr>
                <td>{{ catalog.name }}</td>
                <td>{{ catalog.template.name }}</td>
                <td>
                    {% if catalog.access %}
                        <span class="badge bg-{{ catalog.access.mode.value == 'public' ? 'success' : (catalog.access.mode.value == 'password' ? 'warning' : 'info') }}">
                            {{ catalog.access.mode.value }}
                        </span>
                    {% endif %}
                </td>
                <td>
                    {% if catalog.published %}
                        <span class="badge bg-success">Yes</span>
                    {% else %}
                        <span class="badge bg-secondary">Draft</span>
                    {% endif %}
                </td>
                <td>
                    {% if catalog.published %}
                        <a href="{{ path('catalog_entry', {slug: catalog.slug}) }}" target="_blank" class="text-decoration-none">
                            /c/{{ catalog.slug }} <i class="bi bi-box-arrow-up-right"></i>
                        </a>
                    {% else %}
                        <span class="text-muted">/c/{{ catalog.slug }}</span>
                    {% endif %}
                </td>
                <td>
                    <a href="{{ path('admin_catalog_edit', {id: catalog.id}) }}" class="btn btn-sm btn-outline-primary" title="Edit"><i class="bi bi-pencil"></i></a>
                    <a href="{{ path('admin_catalog_filters', {id: catalog.id}) }}" class="btn btn-sm btn-outline-secondary" title="Filters"><i class="bi bi-funnel"></i></a>
                    <a href="{{ path('admin_catalog_inputs', {id: catalog.id}) }}" class="btn btn-sm btn-outline-secondary" title="Inputs"><i class="bi bi-sliders"></i></a>
                    <a href="{{ path('admin_catalog_access', {id: catalog.id}) }}" class="btn btn-sm btn-outline-secondary" title="Access"><i class="bi bi-lock"></i></a>
                    <form method="post" action="{{ path('admin_catalog_delete', {id: catalog.id}) }}" class="d-inline" onsubmit="return confirm('Delete this catalog?')">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ catalog.id) }}">
                        <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                    </form>
                </td>
            </tr>
            {% else %}
            <tr><td colspan="6" class="text-muted">No catalogs yet.</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
