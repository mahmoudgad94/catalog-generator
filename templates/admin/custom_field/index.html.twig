{% extends 'admin/layout.html.twig' %}

{% block title %}Custom Fields{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Custom Fields</h1>
    <a href="{{ path('admin_custom_field_new') }}" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> New Custom Field
    </a>
</div>

<div class="card">
    <table class="table table-hover mb-0">
        <thead>
            <tr>
                <th>Name</th>
                <th>Slug</th>
                <th>Type</th>
                <th>Required</th>
                <th width="120">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for field in fields %}
            <tr>
                <td>{{ field.name }}</td>
                <td><code>{{ field.slug }}</code></td>
                <td>{{ field.fieldType.value }}</td>
                <td>{{ field.required ? 'Yes' : 'No' }}</td>
                <td>
                    <a href="{{ path('admin_custom_field_edit', {id: field.id}) }}" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                    <form method="post" action="{{ path('admin_custom_field_delete', {id: field.id}) }}" class="d-inline" onsubmit="return confirm('Delete this custom field?')">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ field.id) }}">
                        <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                    </form>
                </td>
            </tr>
            {% else %}
            <tr><td colspan="5" class="text-muted">No custom fields yet.</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
