{% extends 'admin/layout.html.twig' %}

{% block title %}{{ field.id ? 'Edit' : 'New' }} Custom Field{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>{{ field.id ? 'Edit' : 'New' }} Custom Field</h1>
    <a href="{{ path('admin_custom_field_index') }}" class="btn btn-outline-secondary">Back to list</a>
</div>

<div class="card">
    <div class="card-body">
        {{ form_start(form) }}
            <div class="row">
                <div class="col-md-6 mb-3">
                    {{ form_row(form.name) }}
                </div>
                <div class="col-md-6 mb-3">
                    {{ form_row(form.slug) }}
                </div>
            </div>
            <div class="row">
                <div class="col-md-4 mb-3">
                    {{ form_row(form.fieldType) }}
                </div>
                <div class="col-md-4 mb-3">
                    {{ form_row(form.position) }}
                </div>
                <div class="col-md-4 mb-3 pt-4">
                    {{ form_row(form.required) }}
                </div>
            </div>
            <div class="mb-3" id="options-group">
                {{ form_row(form.options) }}
            </div>
            <button type="submit" class="btn btn-primary">{{ field.id ? 'Update' : 'Create' }}</button>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
$(function() {
    function toggleOptions() {
        var type = $('#custom_field_definition_fieldType').val();
        $('#options-group').toggle(type === 'select');
    }
    toggleOptions();
    $('#custom_field_definition_fieldType').on('change', toggleOptions);
});
</script>
{% endblock %}
