<div class="card">
    <table class="table table-hover mb-0">
        <thead>
            <tr>
                <th>Image</th>
                <th>Name</th>
                <th>Price</th>
                <th>Categories</th>
                <th>Tags</th>
                <th width="120">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for product in pagination %}
            <tr>
                <td>
                    {% if product.images|length > 0 %}
                        <img src="/uploads/products/{{ product.images.first.filename }}" alt="" style="width: 40px; height: 40px; object-fit: cover;" class="rounded">
                    {% else %}
                        <span class="text-muted"><i class="bi bi-image" style="font-size: 1.5rem;"></i></span>
                    {% endif %}
                </td>
                <td>{{ product.name }}</td>
                <td>${{ product.price|number_format(2) }}</td>
                <td>
                    {% for cat in product.categories %}
                        <span class="badge bg-secondary">{{ cat.name }}</span>
                    {% endfor %}
                </td>
                <td>
                    {% for tag in product.tags %}
                        <span class="badge bg-info">{{ tag.name }}</span>
                    {% endfor %}
                </td>
                <td>
                    <a href="{{ path('admin_product_edit', {id: product.id}) }}" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                    <form method="post" action="{{ path('admin_product_delete', {id: product.id}) }}" class="d-inline" onsubmit="return confirm('Delete this product?')">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
                        <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                    </form>
                </td>
            </tr>
            {% else %}
            <tr><td colspan="6" class="text-muted">No products found.</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>

<div class="mt-3">
    {{ knp_pagination_render(pagination) }}
</div>
