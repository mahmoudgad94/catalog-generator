{% extends 'admin/layout.html.twig' %}

{% block title %}Import Preview{% endblock %}

{% block body %}
<h1 class="mb-4">Import Preview</h1>

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card text-bg-primary">
            <div class="card-body">
                <h5>Total Rows</h5>
                <p class="display-6">{{ preview.totalRows }}</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-bg-{{ preview.errorCount > 0 ? 'danger' : 'success' }}">
            <div class="card-body">
                <h5>Errors</h5>
                <p class="display-6">{{ preview.errorCount }}</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-bg-info">
            <div class="card-body">
                <h5>New Tags</h5>
                <p class="display-6">{{ preview.newTags|length }}</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-bg-warning">
            <div class="card-body">
                <h5>New Categories</h5>
                <p class="display-6">{{ preview.newCategories|length }}</p>
            </div>
        </div>
    </div>
</div>

{% if preview.newTags|length > 0 %}
<div class="alert alert-info">
    <strong>New tags to create:</strong> {{ preview.newTags|join(', ') }}
</div>
{% endif %}

{% if preview.newCategories|length > 0 %}
<div class="alert alert-warning">
    <strong>New categories to create:</strong> {{ preview.newCategories|join(', ') }}
</div>
{% endif %}

<div class="card mb-4">
    <div class="card-header">Data Preview (first 10 rows)</div>
    <div class="table-responsive">
        <table class="table table-sm table-hover mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    {% for header in preview.headers %}
                        <th>{{ header }}</th>
                    {% endfor %}
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                {% for row in preview.rows|slice(0, 10) %}
                <tr class="{{ row.errors|length > 0 ? 'table-danger' : '' }}">
                    <td>{{ row.row }}</td>
                    {% for header in preview.headers %}
                        <td>{{ row.data[header] ?? '' }}</td>
                    {% endfor %}
                    <td>
                        {% if row.errors|length > 0 %}
                            <span class="text-danger">{{ row.errors|join(', ') }}</span>
                        {% else %}
                            <span class="text-success"><i class="bi bi-check-circle"></i></span>
                        {% endif %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<div class="d-flex gap-2">
    <form method="post" action="{{ path('admin_import_confirm') }}">
        <button type="submit" class="btn btn-success btn-lg" onclick="return confirm('Import {{ preview.totalRows - preview.errorCount }} products?')">
            <i class="bi bi-check-lg"></i> Confirm Import
        </button>
    </form>
    <a href="{{ path('admin_import') }}" class="btn btn-outline-secondary btn-lg">Cancel</a>
</div>
{% endblock %}
