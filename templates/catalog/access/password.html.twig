<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ catalog.name }} - Access Required</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>body { background: #f8f9fa; } .access-card { max-width: 400px; margin: 80px auto; }</style>
</head>
<body>
    <div class="container">
        <div class="access-card">
            <div class="card shadow">
                <div class="card-body p-4">
                    <h4 class="card-title text-center mb-3">{{ catalog.name }}</h4>
                    <p class="text-muted text-center">This catalog is password protected.</p>

                    {% if error %}
                        <div class="alert alert-danger">{{ error }}</div>
                    {% endif %}

                    <form method="post" action="{{ path('catalog_login', {slug: catalog.slug}) }}">
                        <div class="mb-3">
                            <label for="password" class="form-label">Password</label>
                            <input type="password" class="form-control" id="password" name="password" required autofocus>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Access Catalog</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
