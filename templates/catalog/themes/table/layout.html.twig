<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ catalog.name }}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .catalog-header { background: #343a40; color: white; }
    </style>
</head>
<body>
    <div class="catalog-header py-4 mb-4">
        <div class="container">
            <h1>{{ catalog.name }}</h1>
            {% if catalog.description %}<p class="mb-0">{{ catalog.description }}</p>{% endif %}
        </div>
    </div>

    <div class="container">
        {% include 'catalog/themes/grid/filters.html.twig' %}

        <div id="products-container">
            {% include 'catalog/themes/table/products.html.twig' %}
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script>
    $(function() {
        function loadProducts() {
            var params = $('#catalog-filters').serialize() + '&ajax=1';
            $.get('{{ path("catalog_view", {slug: catalog.slug}) }}', params, function(html) {
                $('#products-container').html(html);
            });
        }
        $('#catalog-filters').on('submit', function(e) { e.preventDefault(); loadProducts(); });
        $('#catalog-filters select').on('change', loadProducts);
    });
    </script>
</body>
</html>
