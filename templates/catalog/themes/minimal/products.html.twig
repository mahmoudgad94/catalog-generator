{% for product in products %}
<div class="product-item py-3">
    <div class="d-flex justify-content-between align-items-start">
        <div>
            <h5 class="mb-1">{{ product.name }}</h5>
            {% if product.description %}
                <p class="text-muted mb-1">{{ product.description|slice(0, 150) }}{% if product.description|length > 150 %}...{% endif %}</p>
            {% endif %}
            {% for cat in product.categories %}
                <span class="badge bg-light text-dark">{{ cat.name }}</span>
            {% endfor %}
            {% for tag in product.tags %}
                <span class="badge bg-light text-dark">{{ tag.name }}</span>
            {% endfor %}
        </div>
        <div class="text-end ms-3">
            <span class="fs-5 fw-bold">${{ product.price|number_format(2) }}</span>
        </div>
    </div>
</div>
{% else %}
<p class="text-muted text-center py-5">No products found.</p>
{% endfor %}

{% if pagination.totalItemCount > 24 %}
<nav class="mt-4">{{ knp_pagination_render(pagination) }}</nav>
{% endif %}
