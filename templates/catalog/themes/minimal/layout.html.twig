<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ catalog.name }}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { font-family: 'Georgia', serif; }
        .catalog-header { border-bottom: 2px solid #333; }
        .product-item { border-bottom: 1px solid #eee; }
        .product-item:last-child { border-bottom: none; }
    </style>
</head>
<body>
    <div class="container" style="max-width: 800px;">
        <div class="catalog-header py-4 mb-4">
            <h1>{{ catalog.name }}</h1>
            {% if catalog.description %}<p class="text-muted">{{ catalog.description }}</p>{% endif %}
        </div>

        {% include 'catalog/themes/grid/filters.html.twig' %}

        <div id="products-container">
            {% include 'catalog/themes/minimal/products.html.twig' %}
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script>
    $(function() {
        function loadProducts() {
            var params = $('#catalog-filters').serialize() + '&ajax=1';
            $.get('{{ path("catalog_view", {slug: catalog.slug}) }}', params, function(html) {
                $('#products-container').html(html);
            });
        }
        $('#catalog-filters').on('submit', function(e) { e.preventDefault(); loadProducts(); });
        $('#catalog-filters select').on('change', loadProducts);
    });
    </script>
</body>
</html>
